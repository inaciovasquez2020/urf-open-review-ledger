{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/inaciovasquez2020/urf-core/blob/main/standards/URF-SG/schema.json",
  "title": "URF-SG Certificate Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "operator",
    "hilbert_space",
    "projector",
    "alpha",
    "gram_matrix"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Unique certificate identifier."
    },
    "operator": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Human-readable operator name/description (e.g., Ornstein–Uhlenbeck)."
    },
    "hilbert_space": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Human-readable Hilbert space description (e.g., L2(R, Gaussian))."
    },
    "projector": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Human-readable description of the rigidity projector Per."
    },
    "proof_reference": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "description": "Pointer to a proof artifact (e.g., .tex or .pdf)."
    },
    "alpha": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Certified lower bound alpha > 0 to be checked against the Gram matrix eigenvalues."
    },
    "gram_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "number" }
      },
      "description": "Square real Gram matrix; verifier checks min eigenvalue >= alpha."
    },
    "basis_description": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional human-readable basis labels matching gram_matrix dimension."
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Optional SHA-256 hex digest of the certificate bytes or referenced artifact, depending on project convention."
    },
    "created_utc": {
      "type": "string",
      "format": "date-time",
      "description": "Optional creation timestamp (UTC)."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32,
      "description": "Optional standard version tag (e.g., v1.0)."
    },
    "notes": {
      "type": "string",
      "maxLength": 4000,
      "description": "Optional notes."
    },
    "signature": {
      "type": "string",
      "maxLength": 2048,
      "description": "Optional detached signature (format not enforced here)."
    }
  },
  "allOf": [
    {
      "if": { "required": ["basis_description"] },
      "then": {
        "properties": {
          "basis_description": { "type": "array" },
          "gram_matrix": { "type": "array" }
        }
      }
    }
  ]
}

