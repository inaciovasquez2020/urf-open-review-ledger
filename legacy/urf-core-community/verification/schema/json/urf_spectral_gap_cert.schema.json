{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "URF Spectral Gap Certificate",
  "type": "object",
  "required": ["schema_version", "kind", "id", "created_utc", "n", "epsilon", "L", "P"],
  "properties": {
    "schema_version": { "type": "string" },
    "kind": { "const": "URF_SPECTRAL_GAP_CERT" },
    "id": { "type": "string" },
    "created_utc": { "type": "string" },
    "n": { "type": "integer", "minimum": 1 },
    "epsilon": { "type": "number", "exclusiveMinimum": 0 },
    "L": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "array", "items": { "type": "number" } }
    },
    "P": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "array", "items": { "type": "number" } }
    },
    "notes": { "type": "string" }
  }
}

