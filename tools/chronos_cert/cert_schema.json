{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["instance", "bound", "trace"],
  "properties": {
    "instance": {
      "type": "object",
      "required": ["name", "n_states"],
      "properties": {
        "name": { "type": "string" },
        "n_states": { "type": "integer", "minimum": 2 },
        "H0_lower": { "type": "number", "minimum": 0 }
      }
    },
    "bound": {
      "type": "object",
      "required": ["C"],
      "properties": {
        "C": { "type": "number", "exclusiveMinimum": 0 },
        "epsilon": { "type": "number", "minimum": 0 }
      }
    },
    "trace": {
      "type": "object",
      "required": ["posteriors"],
      "properties": {
        "posteriors": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["p"],
            "properties": {
              "p": {
                "type": "array",
                "items": { "type": "number", "minimum": 0 }
              }
            }
          }
        }
      }
    }
  }
}
