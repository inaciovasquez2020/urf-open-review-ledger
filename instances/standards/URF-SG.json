  "$id": "https://github.com/inaciovasquez2020/urf-core/standards/URF-SG.json",
  "title": "URF Spectral Gap Certification Standard",
  "type": "object",
  "required": ["artifact_id", "operator_type", "spectral_gap_value", "period_kernel_certified"],
  "properties": {
    "artifact_id": { "type": "string" },
    "operator_type": { "type": "string" },
